<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  {% set pageTitle %}{% if title %}{{ title }} | {{ site.name }}{% else %}{{ site.name }} – {{ site.author.jobTitle }}{% endif %}{% endset %}
  {% set pageDescription %}{% if description %}{{ description }}{% else %}{{ site.description }}{% endif %}{% endset %}
  <title>{{ pageTitle | safe }}</title>
  <meta name="description" content="{{ pageDescription | safe }}" />
  <meta name="author" content="{{ site.author.name }}" />
  <link rel="canonical" href="{{ site.url }}{{ page.url }}" />
  <!-- Feed discovery -->
  <link rel="alternate" type="application/atom+xml" title="{{ site.name }} – Articles" href="{{ site.url }}/feed.xml" />
  <!-- Open Graph -->
  <meta property="og:type" content="{% if layout == 'article.njk' %}article{% else %}website{% endif %}" />
  <meta property="og:title" content="{{ pageTitle | safe }}" />
  <meta property="og:description" content="{{ pageDescription | safe }}" />
  <meta property="og:url" content="{{ site.url }}{{ page.url }}" />
  <meta property="og:site_name" content="{{ site.name }}" />
  <meta property="og:locale" content="{{ site.language }}" />
  <meta property="og:image" content="{{ site.url }}/assets/images/cv2.png" />
  <meta property="og:image:alt" content="{{ site.author.name }}" />
  {% if layout == 'article.njk' %}
  <meta property="article:author" content="{{ site.author.name }}" />
  <meta property="article:published_time" content="{{ date | dateISOString }}" />
  {% if tags %}{% for tag in tags %}{% if tag != "articles" %}<meta property="article:tag" content="{{ tag }}" />
  {% endif %}{% endfor %}{% endif %}
  {% endif %}
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content="{{ pageTitle | safe }}" />
  <meta name="twitter:description" content="{{ pageDescription | safe }}" />
  <meta name="twitter:image" content="{{ site.url }}/assets/images/cv2.png" />
  <!-- JSON-LD Structured Data -->
  {% if layout == 'article.njk' %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": "{{ title | safe }}",
    "description": "{{ pageDescription | safe }}",
    "datePublished": "{{ date | dateISOString }}",
    "dateModified": "{{ date | dateISOString }}",
    "url": "{{ site.url }}{{ page.url }}",
    "image": "{{ site.url }}/assets/images/cv2.png",
    "author": {
      "@type": "Person",
      "name": "{{ site.author.name | safe }}",
      "url": "{{ site.url }}",
      "jobTitle": "{{ site.author.jobTitle | safe }}"
    },
    "publisher": {
      "@type": "Person",
      "name": "{{ site.author.name | safe }}",
      "url": "{{ site.url }}"
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "{{ site.url }}{{ page.url }}"
    }{% if tags %},
    "keywords": [{% set ns = { first: true } %}{% for tag in tags %}{% if tag != "articles" %}{% if not ns.first %}, {% endif %}"{{ tag }}"{% set ns = { first: false } %}{% endif %}{% endfor %}]{% endif %}
  }
  </script>
  {% else %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "{{ site.author.name | safe }}",
    "url": "{{ site.url | safe }}",
    "jobTitle": "{{ site.author.jobTitle | safe }}",
    "email": "{{ site.author.email | safe }}",
    "sameAs": [
      "{{ site.author.linkedin | safe }}",
      "{{ site.author.github | safe }}"
    ]
  }
  </script>
  {% endif %}
  <link rel="stylesheet" href="/assets/css/styles.css" />
</head>
<body>
  <header class="site-header">
    <div class="container">
      <a href="/" class="logo">Tom Seidel</a>
      <nav>
        <a href="/">Home</a>
        <a href="/projects/">Projects</a>
        <a href="/articles/">Articles</a>
        <a href="mailto:tom.seidel@remus-software.org" class="btn-contact">Contact</a>
      </nav>
    </div>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div>
          <h4>Tom Seidel</h4>
          <p>Java Freelancer &amp; Cloud-Native AI Specialist</p>
          <p>Based in Germany | Remote-first</p>
        </div>
        <div>
          <h4>Links</h4>
          <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/projects/">Projects</a></li>
            <li><a href="/articles/">Articles</a></li>
            <li><a href="/feed.xml">Atom Feed</a></li>
          </ul>
        </div>
        <div>
          <h4>Contact</h4>
          <ul>
            <li><a href="mailto:tom.seidel@remus-software.org">tom.seidel@remus-software.org</a></li>
            <li><a href="https://linkedin.com/in/tomseidel" target="_blank" rel="noopener">LinkedIn</a></li>
            <li><a href="https://github.com/tmseidel" target="_blank" rel="noopener">GitHub</a></li>
          </ul>
        </div>
      </div>
      <p class="footer-copy">&copy; {{ "" | currentYear }} Tom Seidel. Built with Eleventy.</p>
    </div>
  </footer>

  <!-- Mermaid.js for diagram rendering -->
  <script src="https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js"></script>
  <script>
    mermaid.initialize({ startOnLoad: true, theme: 'default' });
  </script>
  <script src="/assets/js/main.js"></script>
</body>
</html>
