---
permalink: /feed.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ site.name }} – Articles</title>
  <subtitle>{{ site.description }}</subtitle>
  <link href="{{ site.url }}/feed.xml" rel="self" type="application/atom+xml"/>
  <link href="{{ site.url }}/" rel="alternate" type="text/html"/>
  <id>{{ site.url }}/</id>
  <author>
    <name>{{ site.author.name }}</name>
    <email>{{ site.author.email }}</email>
  </author>
  {%- set latestDate = collections.articles | first %}
  {%- if latestDate %}
  <updated>{{ latestDate.date | dateISOString }}</updated>
  {%- endif %}
  {%- for article in collections.articles %}
  <entry>
    <title>{{ article.data.title | escape }}</title>
    <link href="{{ site.url }}{{ article.url }}" rel="alternate" type="text/html"/>
    <id>{{ site.url }}{{ article.url }}</id>
    <published>{{ article.date | dateISOString }}</published>
    <updated>{{ article.date | dateISOString }}</updated>
    {%- if article.data.description %}
    <summary>{{ article.data.description | escape }}</summary>
    {%- endif %}
    <content type="html">{{ article.templateContent | escape }}</content>
    <author>
      <name>{{ site.author.name }}</name>
    </author>
    {%- if article.data.tags %}
    {%- for tag in article.data.tags %}{% if tag != "articles" %}
    <category term="{{ tag }}"/>
    {%- endif %}{%- endfor %}
    {%- endif %}
  </entry>
  {%- endfor %}
</feed>

