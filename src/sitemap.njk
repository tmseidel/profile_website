---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {%- for page in collections.all %}
  {%- if page.url and page.url != false %}
  <url>
    <loc>{{ site.url }}{{ page.url }}</loc>
    <lastmod>{{ page.date | dateISOString }}</lastmod>
    <changefreq>{% if page.url == "/" %}weekly{% elif "articles" in page.url and page.url != "/articles/" %}monthly{% else %}weekly{% endif %}</changefreq>
    <priority>{% if page.url == "/" %}1.0{% elif page.url == "/articles/" or page.url == "/projects/" %}0.8{% else %}0.6{% endif %}</priority>
  </url>
  {%- endif %}
  {%- endfor %}
</urlset>
